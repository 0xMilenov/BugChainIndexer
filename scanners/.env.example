# Database Configuration
PGHOST=localhost
PGPORT=5432
PGDATABASE=bugchain_indexer
PGUSER=postgres
PGPASSWORD=your_password_here

# Etherscan API Keys (comma-separated)
DEFAULT_ETHERSCAN_KEYS=key1,key2,key3

# Public RPC mode is the default. Keep this true in production and public repo config.
PUBLIC_RPC_ONLY=true

# Private/provider RPCs are opt-in only in private environments.
# USE_ALCHEMY_RPC=false

# Etherscan Proxy Server Configuration (disabled by default)
USE_ETHERSCAN_PROXY=false
ETHERSCAN_PROXY_URL=http://localhost:3000

# Explorer API budget tracking (Etherscan V2 enrichment only; balances use RPC)
ETHERSCAN_DAILY_SOFT_LIMIT=80000

# Free price source for FundUpdater
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3

# Scanner Configuration
TIMEDELAY_HOURS=4
FUNDUPDATEDELAY_DAYS=7
TIMEOUT_SECONDS=7200
ERC20_TOKEN_LIMIT=15
FUND_TOKEN_LIMIT=15

# Per-chain RPC overrides (optional - sensible public defaults are baked in)
# SUBTENSOR_RPC_URL=https://lite.chain.opentensor.ai
