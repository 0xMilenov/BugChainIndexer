[Unit]
Description=Next.js Frontend for BugChain Indexer
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/claude/BugChainIndexer/server/frontend-next
ExecStart=/usr/bin/npm run start
Restart=on-failure
User=root
Environment=PORT=3000
Environment=NODE_ENV=production
Environment=NEXT_PUBLIC_API_URL=http://localhost:8000
Environment=NEXT_PUBLIC_APP_URL=https://app.visualisa.xyz

[Install]
WantedBy=multi-user.target
